# Default local model store inside this repository.
# HYPERMOTION_MODEL_ROOT=assets/model_store

# Optional X-Pose checkout or weights directory.
HYPERMOTION_XPOSE_ROOT=assets/xpose

# Optional output overrides.
HYPERMOTION_OUTPUTS_ROOT=outputs
HYPERMOTION_LOGS_ROOT=logs

# External-drive example for macOS:
HYPERMOTION_MODEL_ROOT=/Volumes/E/Coding/hypermotion-models
